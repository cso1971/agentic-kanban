{
  "rules": [
    {
      "event": "issue",
      "action": "update",
      "label": "agent:review",
      "prompt": "./prompts/review.md",
      "workingDirectory": "./repos/{{project_path}}"
    },
    {
      "event": "issue",
      "action": "update",
      "label": "agent:fix",
      "prompt": "./prompts/fix.md",
      "workingDirectory": "./repos/{{project_path}}"
    },
    {
      "event": "issue",
      "action": "update",
      "label": "agent:docs",
      "prompt": "./prompts/docs.md",
      "workingDirectory": "./repos/{{project_path}}"
    }
  ]
}
