{
	"name": "@agentic-kanban/cli",
	"version": "0.1.0",
	"type": "module",
	"imports": {
		"#*": {
			"types": [
				"./src/*.d.ts",
				"./src/*.ts",
				"./src/*.tsx",
				"./src/*"
			],
			"default": [
				"./src/*"
			]
		}
	},
	"bin": {
		"cli": "src/cli.ts"
	},
	"scripts": {
		"cli": "bun run --env-file=../../.env src/cli.ts",
		"test": "bun test --pass-with-no-tests",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@agentic-kanban/core": "workspace:*",
		"@agentic-kanban/gitlab": "workspace:*",
		"@agentic-kanban/queue": "workspace:*",
		"commander": "^14.0.3"
	},
	"devDependencies": {
		"@typescript/native-preview": "catalog:",
		"bun-types": "catalog:"
	}
}
