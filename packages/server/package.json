{
	"name": "@agentic-kanban/server",
	"version": "0.1.0",
	"type": "module",
	"imports": {
		"#*": {
			"types": [
				"./src/*.d.ts",
				"./src/*.ts",
				"./src/*.tsx",
				"./src/*"
			],
			"default": [
				"./src/*"
			]
		}
	},
	"main": "src/server.ts",
	"scripts": {
		"dev": "bun run --env-file=../../.env --watch src/server.ts",
		"start": "bun run --env-file=../../.env src/server.ts",
		"test": "bun test --pass-with-no-tests",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@agentic-kanban/core": "workspace:*",
		"@agentic-kanban/queue": "workspace:*",
		"@bull-board/api": "catalog:",
		"@bull-board/hono": "catalog:",
		"@hono/swagger-ui": "catalog:",
		"@hono/zod-openapi": "catalog:",
		"hono": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@typescript/native-preview": "catalog:",
		"bun-types": "catalog:",
		"gitlab-event-types": "^3.0.1"
	}
}
