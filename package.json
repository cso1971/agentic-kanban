{
	"private": true,
	"scripts": {
		"biome:ci": "biome ci . --error-on-warnings",
		"biome:fix": "biome check . --write --error-on-warnings",
		"build": "turbo run build",
		"cli": "pnpm run -F @agentic-kanban/cli cli",
		"dev": "turbo run dev",
		"docker:all:down": "docker compose -f docker-compose.yml -f docker-compose.gitlab.yml down",
		"docker:all:up": "docker compose -f docker-compose.yml -f docker-compose.gitlab.yml up -d",
		"docker:down": "docker compose down",
		"docker:down:force": "docker compose down -v --remove-orphans",
		"docker:gitlab:down": "docker compose -f docker-compose.gitlab.yml down",
		"docker:gitlab:up": "docker compose -f docker-compose.gitlab.yml up -d",
		"docker:up": "docker compose up -d",
		"example:setup": "pnpm run cli gitlab config -g 'cool' -c ../../examples/calculator/config -r ../../examples/calculator/config ../../examples/calculator/repository -t ../../examples/calculator/repository -w http://host.docker.internal:4300/webhook/gitlab --force",
		"example:trigger:docs": "pnpm run cli run -p ../../examples/calculator/config/triggers/docs.md -w ../../examples/calculator/repository",
		"generate": "turbo run generate",
		"postinstall": "lefthook install",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck"
	},
	"dependencies": {
		"@logtape/logtape": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"lefthook": "catalog:",
		"sort-package-json": "catalog:",
		"turbo": "catalog:"
	},
	"packageManager": "pnpm@10.32.1"
}
