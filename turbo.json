{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"cli": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"generate": {
			"dependsOn": ["^generate"]
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {}
	}
}
